{
  "name": "@infinite-canvas-tutorial/particle",
  "version": "0.0.1",
  "description": "WebGPU GPU particles for ECS / device-api (Spectrum) canvases",
  "main": "lib/index.js",
  "module": "esm/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./esm/index.js",
      "require": "./lib/index.js"
    }
  },
  "files": [
    "package.json",
    "esm",
    "lib",
    "README.md"
  ],
  "keywords": [
    "whiteboard",
    "infinite canvas",
    "webgpu",
    "particles"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoiver/infinite-canvas-tutorial"
  },
  "license": "MIT",
  "author": {
    "name": "xiaoiver",
    "url": "https://github.com/xiaoiver"
  },
  "scripts": {
    "build:cjs": "rimraf ./lib && tsc --module commonjs --outDir lib",
    "build:esm": "rimraf ./esm && tsc --module ESNext --outDir esm",
    "build": "run-p build:*",
    "watch": "rimraf ./esm && tsc --module ESNext --outDir esm --watch"
  },
  "dependencies": {
    "@infinite-canvas-tutorial/device-api": "workspace:*",
    "@loaders.gl/core": "^4.4.1",
    "@loaders.gl/draco": "^4.4.1",
    "@loaders.gl/gltf": "^4.4.1",
    "@loaders.gl/obj": "^4.4.1"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "rimraf": "^4.4.1",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
