{
  "name": "@infinite-canvas-tutorial/gsplat",
  "version": "0.0.1",
  "description": "3D Gaussian Splatting (3DGS) renderer for ECS / device-api canvases",
  "main": "lib/index.js",
  "module": "esm/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./esm/index.js",
      "require": "./lib/index.js"
    }
  },
  "files": [
    "package.json",
    "esm",
    "lib",
    "README.md"
  ],
  "keywords": [
    "whiteboard",
    "infinite canvas",
    "webgpu",
    "webgl",
    "gaussian-splatting",
    "3dgs",
    "splat"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoiver/infinite-canvas-tutorial"
  },
  "license": "MIT",
  "author": {
    "name": "xiaoiver",
    "url": "https://github.com/xiaoiver"
  },
  "scripts": {
    "build:cjs": "rimraf ./lib && tsc -p tsconfig.build.json --module commonjs --outDir lib",
    "build:esm": "rimraf ./esm && tsc -p tsconfig.build.json --module ESNext --outDir esm",
    "build": "run-p build:*",
    "watch": "rimraf ./esm && tsc -p tsconfig.build.json --module ESNext --outDir esm --watch"
  },
  "dependencies": {
    "@infinite-canvas-tutorial/device-api": "workspace:*",
    "gl-matrix": "^3.4.3"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "rimraf": "^4.4.1",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
